<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for hardened runtime: allows JIT compilation used by Chromium/V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for hardened runtime: allows unsigned executable memory (V8 snapshots) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for hardened runtime: allows DYLD environment variables used by Electron -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Disable Apple sandbox for Electron main process (required for file system access) -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Allow reading/writing user-selected files (userData path for supertasks.json) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
  </dict>
</plist>
