{
  "name": "supertasks",
  "version": "1.0.0",
  "description": "Superhuman-inspired keyboard-first task manager",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:electron": "npm run build && electron-builder",
    "seo:build": "node seo/build.js"
  },
  "keywords": [],
  "author": "Ali Mirza",
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "date-fns": "^3.3.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.0.3",
    "fuse.js": "^7.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.supertasks.app",
    "productName": "Supertasks",
    "copyright": "Copyright © 2026 Ali Mirza",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "afterSign": "build/notarize.cjs",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Supertasks",
      "icon": "assets/icon.icns",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
